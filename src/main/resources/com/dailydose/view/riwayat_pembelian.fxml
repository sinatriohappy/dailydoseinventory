<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  RIWAYAT PEMBELIAN VIEW
  Menampilkan semua riwayat transaksi restock/pembelian dari supplier.
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.dailydose.controller.RiwayatPembelianController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #f0f4f8;">

    <!-- ===== TOP: Header ===== -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 12 20;"
              alignment="CENTER_LEFT" spacing="15">
            <Button text="← Dashboard" onAction="#kembaliDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Label text="📦 Riwayat Pembelian (Restock)"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ===== CENTER ===== -->
    <center>
        <VBox spacing="12" style="-fx-padding: 15;">

            <!-- TABEL HEADER PEMBELIAN -->
            <VBox style="-fx-background-color: white; -fx-padding: 15;
                         -fx-background-radius: 8; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                <Label text="Daftar Transaksi Pembelian"
                       style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 0 0 8 0;"/>

                <TableView fx:id="tabelPembelian" prefHeight="220"
                           onMouseClicked="#handlePilihTransaksi"
                           style="-fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colIdPembelian" text="ID Pembelian"  prefWidth="100"/>
                        <TableColumn fx:id="colTanggal"     text="Tanggal"       prefWidth="140"/>
                        <TableColumn fx:id="colTotal"       text="Total Pembayaran"   prefWidth="130"/>
                        <TableColumn fx:id="colNamaToko"    text="Nama Toko"     prefWidth="150"/>
                        <TableColumn fx:id="colIdUser"      text="ID Admin"      prefWidth="70"/>
                    </columns>
                    <placeholder>
                        <Label text="Belum ada riwayat pembelian."/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- TABEL DETAIL ITEM -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-padding: 15;
                         -fx-background-radius: 8; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">

                <Label fx:id="lblDetailHeader" text="Detail Transaksi — Pilih transaksi di atas"
                       style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 0 0 8 0;"/>

                <TableView fx:id="tabelDetail" VBox.vgrow="ALWAYS"
                           style="-fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colDetailBarang"  text="ID Barang"   prefWidth="100"/>
                        <TableColumn fx:id="colDetailNama"    text="Nama Barang" prefWidth="220"/>
                        <TableColumn fx:id="colDetailJumlah"  text="Jumlah Beli" prefWidth="80"/>
                        <TableColumn fx:id="colDetailHarga"   text="Harga Beli (Modal)" prefWidth="150"/>
                        <TableColumn fx:id="colDetailSubtotal" text="Subtotal"   prefWidth="150"/>
                    </columns>
                    <placeholder>
                        <Label text="Pilih transaksi untuk melihat detail item."/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>
